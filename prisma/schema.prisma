// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  lovenseUid String   @unique // The UID from Lovense
  nickname  String?  // Optional nickname from Lovense uname
  highScore Int      @default(0)
  patterns  Json?    // Store custom vibration patterns here
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GameSession {
  id        String   @id @default(uuid())
  hostUid   String
  guestUid  String?
  startedAt DateTime @default(now())
  endedAt   DateTime?
  score     Int      @default(0)
}
